# API própria do Barber Hub — nunca envie o arquivo .env real ao GitHub.
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Preferidos em projetos atuais do Supabase
SUPABASE_PUBLISHABLE_KEY=sb_publishable_EXEMPLO
SUPABASE_SECRET_KEY=sb_secret_EXEMPLO

# Compatibilidade com chaves legadas (use somente se o projeto ainda depender delas)
# SUPABASE_ANON_KEY=SUA_CHAVE_ANON
# SUPABASE_SERVICE_ROLE_KEY=SUA_CHAVE_SERVICE_ROLE

# Opcional: origens extras para previews e futuro aplicativo Capacitor.
BARBER_HUB_ALLOWED_ORIGINS=https://barberhuboficial.vercel.app
